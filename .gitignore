# ============================================================
# Python
# ============================================================
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Ambientes virtuais
.venv/
venv/
env/

# ============================================================
# Jupyter
# ============================================================
.ipynb_checkpoints/

# ============================================================
# Dados (conteúdo não versionado, estrutura sim via .gitkeep)
# ============================================================
data/raw/
data/staging/
data/marts/
*.parquet
*.duckdb
*.duckdb.wal

# Exceções para preservar a estrutura de pastas
!data/raw/.gitkeep
!data/staging/.gitkeep
!data/marts/.gitkeep

# ============================================================
# Etapa 3 — DuckDB warehouse local (regenerável a partir do MinIO)
# ============================================================
warehouse.duckdb
warehouse.duckdb.wal

# ============================================================
# Secrets e credenciais
# ============================================================
.env
.env.local
*.pem
*.key
credentials.json

# ============================================================
# IDE e editores
# ============================================================
.vscode/
.idea/
*.swp
*.swo

# ============================================================
# Configuração local de ferramentas (não versionada)
# ============================================================
# M7: permissões locais do Claude Code (específicas da máquina/usuário).
# Template versionado em .claude/settings.example.json.
.claude/settings.local.json
# M8: estado local do dbt (user_id anônimo de telemetria), por máquina.
dbt/.user.yml

# ============================================================
# Sistema operacional
# ============================================================
.DS_Store
Thumbs.db

# ============================================================
# Logs
# ============================================================
*.log
logs/

# ============================================================
# dbt (Etapa 4)
# ============================================================
dbt/target/
dbt/dbt_packages/
dbt/logs/
# Não ignorar dbt/profiles.yml: decisão consciente de versionar
# (consome credenciais via env_var, sem segredos no arquivo).

# ============================================================
# Airflow (Etapa 5)
# ============================================================
airflow.db
airflow.cfg
webserver_config.py
airflow-webserver.pid

# Logs e plugins do Airflow são bind-mounts ativos: o conteúdo é
# gerado em runtime e não vai para o repo. Dois cuidados aqui:
#   1) Padrão `dir/*` (não `dir/`) — com `dir/` git nem entra na pasta
#      e a negação `!dir/.gitkeep` não tem efeito.
#   2) A regra geral `logs/` na seção "Logs" deste arquivo casaria com
#      airflow/logs e bloquearia o `airflow/logs/.gitkeep` mesmo com
#      a negação aqui embaixo. Por isso negamos a pasta inteira ANTES,
#      depois ignoramos seu conteúdo.
!airflow/logs/
!airflow/plugins/
airflow/logs/*
airflow/plugins/*
!airflow/logs/.gitkeep
!airflow/plugins/.gitkeep
