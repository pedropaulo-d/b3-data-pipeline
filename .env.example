# Copie este arquivo para .env e ajuste credenciais se necessário.
# NUNCA commite .env — ele está listado em .gitignore.
#
# Em produção real, MINIO_ROOT_* (admin do servidor) e MINIO_ACCESS/SECRET
# (chaves de aplicação) seriam credenciais distintas com permissões
# diferentes. Para o ambiente local de portfólio, reaproveitamos as
# mesmas para simplificar — o objetivo é exercitar a integração, não a
# administração de IAM.

# ----------------------------------------------------------------
# MinIO — Object Storage (compatível S3 API)
# ----------------------------------------------------------------

# Endpoint do servidor S3 (MinIO local via Docker Compose).
MINIO_ENDPOINT=http://localhost:9000

# Mesmo endpoint, sem esquema (apenas host:porta). Usado pelo
# dbt-duckdb (settings: s3_endpoint) — o DuckDB recusa URL completa
# nesse parâmetro. Mantemos as duas variáveis em vez de derivar uma
# da outra porque cada consumidor (Python/boto3 vs dbt/DuckDB) tem
# expectativa diferente sobre o formato.
MINIO_ENDPOINT_HOST_PORT=localhost:9000

# Credenciais do administrador do MinIO (consumidas pelo container).
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# Credenciais usadas pelo cliente Python (boto3). No ambiente local,
# iguais às do admin.
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# Bucket único do projeto. Prefixos internos seguem o layout do data
# lake: raw/, staging/, marts/.
MINIO_BUCKET=b3-data

# Região: o S3 protocol exige uma. MinIO ignora o valor, mas o boto3
# levanta erro se não for informado.
MINIO_REGION=us-east-1

# ----------------------------------------------------------------
# Airflow / Postgres — Orquestração (Etapa 5)
# ----------------------------------------------------------------
# Todos os valores abaixo têm default seguro no docker-compose.yml
# (${VAR:-default}); este arquivo serve para sobrescrevê-los e como
# documentação. Em produção, NÃO use estes valores.

# Senha do Postgres que serve de metastore do Airflow. Usada tanto pelo
# serviço `postgres` quanto pela connection string do Airflow.
# dev local — trocar em produção
POSTGRES_PASSWORD=airflow

# Credenciais do usuário admin criado pelo airflow-init na primeira
# subida (login da UI em http://localhost:8080).
# dev local — trocar em produção
AIRFLOW_ADMIN_USERNAME=admin
AIRFLOW_ADMIN_PASSWORD=admin

# Secret key do webserver (assina cookies de sessão e tokens CSRF).
# Gere a sua com:
#   python -c "import secrets; print(secrets.token_hex(32))"
# Dev local pode usar qualquer valor (ou deixar vazio para cair no
# placeholder do compose); produção EXIGE valor único e secreto.
AIRFLOW_SECRET_KEY=
